#!/bin/sh -

cp uv.lock uv.lock.old

docker build \
	--file ../Dockerfile \
	--target backend-dev \
	--tag backend-update-lock \
	--build-arg UID="$(id -u)" \
	--build-arg GID="$(id -g)" \
	. &&
docker run \
	--rm \
	--volume './:/home/psc-atlas/backend' \
	backend-update-lock \
	uv sync --upgrade

if ! cmp -s uv.lock uv.lock.old
then
	echo 'UV lock updated'
else
	echo 'UV lock did not need updating'
fi

rm -f uv.lock.old
