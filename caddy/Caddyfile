# Serve static export in production, proxy to development server in
# development.

:80

# Health endpoint
handle {$CADDY_API_ROOT}/health {
	respond "{\"status\":\"ok\"}" 200
}

@dev {
	expression "{$SERVICE_MODE}" == "development"
}
@prod {
	expression "{$SERVICE_MODE}" == "production"
}

handle {$CADDY_API_ROOT}/* {
	reverse_proxy localhost:8000
}

handle @dev {
	reverse_proxy psc-atlas-frontend:3000
}

handle @prod {
	root * ./frontend
	file_server
}
